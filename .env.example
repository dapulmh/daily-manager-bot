# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=123456789          # your numeric Telegram user ID

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json   # downloaded from Google Cloud Console
GOOGLE_TOKEN_FILE=token.json               # auto-generated on first run
GOOGLE_CALENDAR_ID=primary                 # or a specific calendar ID

# ── Trello ────────────────────────────────────────────────────────────────────
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id

# ── Groq (free NLP) ───────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192          # free tier, fast

# ── General ───────────────────────────────────────────────────────────────────
TIMEZONE=Asia/Jakarta
